{
  "openapi": "3.0.3",
  "info": {
    "title": "Property Rental - Admin API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/admin/listings/pending": {
      "get": {
        "summary": "Get paginated listing moderation queue (PENDING_REVIEW)",
        "tags": ["Admin - Listings"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Paginated list of pending listings" },
          "403": { "description": "Not a Property Manager or Admin" }
        }
      }
    },
    "/api/v1/admin/listings/{id}/approve": {
      "post": {
        "summary": "Approve a pending listing (PENDING_REVIEW -> ACTIVE)",
        "tags": ["Admin - Listings"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Listing approved and set to ACTIVE" },
          "409": { "description": "Listing is not in PENDING_REVIEW status" }
        }
      }
    },
    "/api/v1/admin/listings/{id}/reject": {
      "post": {
        "summary": "Reject a pending listing (PENDING_REVIEW -> DRAFT)",
        "tags": ["Admin - Listings"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ModerationActionRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Listing rejected and moved back to DRAFT. Host notified." }
        }
      }
    },
    "/api/v1/admin/listings/{id}/suspend": {
      "post": {
        "summary": "Suspend an active listing (ACTIVE -> SUSPENDED)",
        "tags": ["Admin - Listings"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ModerationActionRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Listing suspended" }
        }
      }
    },
    "/api/v1/admin/users": {
      "get": {
        "summary": "Search and list all users (paginated)",
        "tags": ["Admin - Users"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "query", "in": "query", "schema": { "type": "string" } },
          { "name": "role", "in": "query", "schema": { "type": "string" } },
          { "name": "isActive", "in": "query", "schema": { "type": "boolean" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "Paginated list of users" }
        }
      }
    },
    "/api/v1/admin/users/{id}/deactivate": {
      "post": {
        "summary": "Deactivate a user account and invalidate tokens",
        "tags": ["Admin - Users"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "User deactivated. All active sessions invalidated." }
        }
      }
    },
    "/api/v1/admin/users/{id}/change-role": {
      "patch": {
        "summary": "Change a user's role (Super Admin only)",
        "tags": ["Admin - Users"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChangeRoleRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "User role updated" }
        }
      }
    },
    "/api/v1/admin/host-applications": {
      "get": {
        "summary": "Get paginated host applications for review",
        "tags": ["Admin - Host Applications"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Paginated list of pending host applications" }
        }
      }
    },
    "/api/v1/admin/host-applications/{id}/approve": {
      "post": {
        "summary": "Approve a host application and upgrade user to HOST role",
        "tags": ["Admin - Host Applications"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Host approved. User role changed to HOST. Email sent." }
        }
      }
    },
    "/api/v1/admin/host-applications/{id}/reject": {
      "post": {
        "summary": "Reject a host application with a justification",
        "tags": ["Admin - Host Applications"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ModerationActionRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Host application rejected. Email sent with reason." }
        }
      }
    },
    "/api/v1/admin/config": {
      "get": {
        "summary": "Get current platform configuration (Super Admin only)",
        "tags": ["Admin - Platform Config"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Current PlatformConfig values" }
        }
      },
      "put": {
        "summary": "Update platform configuration (Super Admin only)",
        "tags": ["Admin - Platform Config"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdatePlatformConfigRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Platform configuration updated" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ModerationActionRequest": {
        "type": "object",
        "required": ["reason"],
        "properties": {
          "reason": { "type": "string", "minLength": 10, "maxLength": 1000 }
        }
      },
      "ChangeRoleRequest": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": { "type": "string", "enum": ["SUPER_ADMIN","PROPERTY_MANAGER","HOST","GUEST","SUPPORT_AGENT"] }
        }
      },
      "UpdatePlatformConfigRequest": {
        "type": "object",
        "properties": {
          "serviceFeePercent": { "type": "number", "minimum": 0, "maximum": 100 },
          "taxRatePercent": { "type": "number", "minimum": 0, "maximum": 100 },
          "payoutDelayDays": { "type": "integer", "minimum": 0 },
          "cancellationPolicy": { "type": "string", "enum": ["FLEXIBLE","MODERATE","STRICT"] }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  }
}
